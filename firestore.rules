rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signed() {
      return request.auth != null;
    }

    function space(spaceId) {
      return get(/databases/$(database)/documents/spaces/$(spaceId));
    }

    function member(spaceId) {
      return signed() && request.auth.uid in space(spaceId).data.memberIds;
    }

    function owner(spaceId) {
      return signed() && space(spaceId).data.ownerId == request.auth.uid;
    }

    function admin(spaceId) {
      return member(spaceId) && request.auth.uid in space(spaceId).data.adminIds;
    }

    function validInvite(spaceId, code) {
      return exists(/databases/$(database)/documents/invitations/$(code))
        && get(/databases/$(database)/documents/invitations/$(code)).data.spaceId == spaceId
        && get(/databases/$(database)/documents/invitations/$(code)).data.expiresAt > request.time;
    }

    match /users/{uid} {
      allow create, read, update: if signed() && request.auth.uid == uid;
    }

    match /spaces/{spaceId} {
      allow create: if signed()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Use resource data directly so Firestore can authorize the
      // memberIds array-contains query used by the live Space subscription.
      allow read: if signed() && request.auth.uid in resource.data.memberIds;

      allow update: if
        (
          owner(spaceId)
          && request.resource.data.ownerId == resource.data.ownerId
        )
        ||
        (
          admin(spaceId)
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'emoji', 'type', 'categories', 'reactionDefs', 'updatedAt'])
        )
        ||
        (
          member(spaceId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['categories', 'updatedAt'])
        )
        ||
        (
          member(spaceId)
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.memberIds == resource.data.memberIds
          && request.resource.data.memberNames[request.auth.uid] is string
          && (
            (
              'memberNames' in resource.data
              && request.resource.data.memberNames.diff(resource.data.memberNames).affectedKeys()
                .hasOnly([request.auth.uid])
            )
            ||
            (
              !('memberNames' in resource.data)
              && request.resource.data.memberNames.keys().hasOnly([request.auth.uid])
            )
          )
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberNames', 'updatedAt'])
        )
        ||
        (
          signed()
          && !(request.auth.uid in resource.data.memberIds)
          && resource.data.deletedAt == null
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.toSet().difference(resource.data.memberIds.toSet())
            .hasOnly([request.auth.uid])
          && resource.data.memberIds.toSet().difference(request.resource.data.memberIds.toSet())
            .size() == 0
          && request.resource.data.memberNames[request.auth.uid] is string
          && (
            (
              'memberNames' in resource.data
              && request.resource.data.memberNames.diff(resource.data.memberNames).affectedKeys()
                .hasOnly([request.auth.uid])
            )
            ||
            (
              !('memberNames' in resource.data)
              && request.resource.data.memberNames.keys().hasOnly([request.auth.uid])
            )
          )
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberIds', 'memberNames', 'updatedAt'])
          && existsAfter(/databases/$(database)/documents/spaces/$(spaceId)/joinClaims/$(request.auth.uid))
        );

      allow delete: if owner(spaceId);

      match /joinClaims/{uid} {
        allow create: if signed()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'code', 'createdAt'])
          && validInvite(spaceId, request.resource.data.code);
        allow read, delete: if signed() && (request.auth.uid == uid || owner(spaceId));
        allow update: if false;
      }
    }

    match /ideas/{ideaId} {
      allow create: if member(request.resource.data.spaceId)
        && request.resource.data.createdBy == request.auth.uid;

      allow read: if member(resource.data.spaceId);

      allow update: if member(resource.data.spaceId)
        && request.resource.data.spaceId == resource.data.spaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['completed', 'completedAt'])
          || owner(resource.data.spaceId)
        );

      allow delete: if member(resource.data.spaceId)
        && (resource.data.createdBy == request.auth.uid || owner(resource.data.spaceId));

      match /reactions/{uid} {
        allow read: if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
        allow write: if signed()
          && request.auth.uid == uid
          && member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
      }

      match /comments/{commentId} {
        allow read: if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
        allow create: if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId)
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if signed()
          && resource.data.authorId == request.auth.uid
          && member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
      }
    }

    match /plans/{ideaId} {
      allow read: if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
      allow create: if member(request.resource.data.spaceId)
        && request.resource.data.ideaId == ideaId;
      allow update: if member(resource.data.spaceId)
        && request.resource.data.spaceId == resource.data.spaceId
        && request.resource.data.ideaId == resource.data.ideaId;
      allow delete: if owner(resource.data.spaceId);
    }

    match /memories/{ideaId} {
      allow read: if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);
      allow create: if member(request.resource.data.spaceId)
        && request.resource.data.ideaId == ideaId;
      allow update: if member(resource.data.spaceId)
        && request.resource.data.spaceId == resource.data.spaceId
        && request.resource.data.ideaId == resource.data.ideaId;
      allow delete: if owner(resource.data.spaceId);

      match /reflections/{uid} {
        allow read: if member(get(/databases/$(database)/documents/memories/$(ideaId)).data.spaceId);
        allow create, update, delete: if signed()
          && request.auth.uid == uid
          && member(get(/databases/$(database)/documents/memories/$(ideaId)).data.spaceId);
      }
    }

    match /activity/{activityId} {
      allow create: if member(request.resource.data.spaceId)
        && request.resource.data.actorId == request.auth.uid;
      allow read: if member(resource.data.spaceId);
    }

    match /invitations/{code} {
      allow create: if member(request.resource.data.spaceId)
        && request.resource.data.code == code
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(8, 'd');
      allow get: if signed() && resource.data.expiresAt > request.time;
      allow list: if false;
      allow delete: if signed()
        && (request.auth.uid == resource.data.invitedBy || owner(resource.data.spaceId));
      allow update: if false;
    }
  }
}
