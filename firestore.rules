rules_version='2';
service cloud.firestore{match/databases/{database}/documents{
function signed(){return request.auth!=null;}
function space(id){return get(/databases/$(database)/documents/spaces/$(id));}
function member(id){return signed()&&request.auth.uid in space(id).data.memberIds;}
function owner(id){return signed()&&space(id).data.ownerId==request.auth.uid;}
function manager(id){return owner(id)||request.auth.uid in space(id).data.adminIds;}
match/users/{uid}{allow create,read,update:if signed()&&request.auth.uid==uid;}
match/spaces/{id}{
allow create:if signed()&&request.resource.data.ownerId==request.auth.uid&&request.auth.uid in request.resource.data.memberIds;
allow read:if signed()&&request.auth.uid in resource.data.memberIds;
allow update:if manager(id)||(member(id)&&request.resource.data.diff(resource.data).affectedKeys().hasOnly(['categories','updatedAt']))||(signed()&&!(request.auth.uid in resource.data.memberIds)&&request.auth.uid in request.resource.data.memberIds&&request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds','memberNames','updatedAt']));
allow delete:if owner(id);}
match/ideas/{id}{
allow create:if member(request.resource.data.spaceId)&&request.resource.data.createdBy==request.auth.uid;
allow read:if member(resource.data.spaceId);
allow update:if member(resource.data.spaceId)&&(!request.resource.data.diff(resource.data).affectedKeys().hasAny(['completed','completedAt'])||owner(resource.data.spaceId));
allow delete:if member(resource.data.spaceId)&&(resource.data.createdBy==request.auth.uid||owner(resource.data.spaceId));
match/reactions/{uid}{allow read:if member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId);allow write:if signed()&&request.auth.uid==uid&&member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId);}
match/comments/{commentId}{allow read:if member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId);allow create:if member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId)&&request.resource.data.authorId==request.auth.uid;allow update,delete:if signed()&&resource.data.authorId==request.auth.uid;}}
match/plans/{id}{allow read:if member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId);allow create:if member(request.resource.data.spaceId);allow update:if member(resource.data.spaceId);allow delete:if owner(resource.data.spaceId);}
match/memories/{id}{allow read:if member(get(/databases/$(database)/documents/ideas/$(id)).data.spaceId);allow create:if member(request.resource.data.spaceId);allow update:if member(resource.data.spaceId);allow delete:if owner(resource.data.spaceId);match/reflections/{uid}{allow read:if member(get(/databases/$(database)/documents/memories/$(id)).data.spaceId);allow create,update,delete:if signed()&&request.auth.uid==uid&&member(get(/databases/$(database)/documents/memories/$(id)).data.spaceId);}}
match/activity/{id}{allow create:if member(request.resource.data.spaceId)&&request.resource.data.actorId==request.auth.uid;allow read:if member(resource.data.spaceId);}
match/invitations/{id}{allow create:if member(request.resource.data.spaceId);allow read:if signed();allow delete:if signed()&&request.auth.uid==resource.data.invitedBy;}
}}

