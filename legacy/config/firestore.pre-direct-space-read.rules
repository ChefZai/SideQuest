rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){return request.auth!=null;}
    function space(spaceId){return get(/databases/$(database)/documents/spaces/$(spaceId));}
    function member(spaceId){return signedIn()&&request.auth.uid in space(spaceId).data.memberIds;}
    function owner(spaceId){return signedIn()&&space(spaceId).data.ownerId==request.auth.uid;}
    match /users/{userId}{allow create,read,update:if signedIn()&&request.auth.uid==userId;}
    match /spaces/{spaceId}{
      allow create:if signedIn()&&request.resource.data.ownerId==request.auth.uid&&request.auth.uid in request.resource.data.memberIds;
      allow read:if member(spaceId);
      allow update:if member(spaceId)||(signedIn()&&!(request.auth.uid in resource.data.memberIds)&&request.auth.uid in request.resource.data.memberIds&&request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds','updatedAt']));
      allow delete:if owner(spaceId);
    }
    match /ideas/{ideaId}{
      allow create:if member(request.resource.data.spaceId)&&request.resource.data.createdBy==request.auth.uid;
      allow read,update:if member(resource.data.spaceId);
      allow delete:if member(resource.data.spaceId)&&(resource.data.createdBy==request.auth.uid||owner(resource.data.spaceId));
      match /reactions/{userId}{allow read:if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);allow write:if signedIn()&&request.auth.uid==userId&&member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);}
      match /comments/{commentId}{allow read:if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId);allow create:if member(get(/databases/$(database)/documents/ideas/$(ideaId)).data.spaceId)&&request.resource.data.authorId==request.auth.uid;allow update,delete:if signedIn()&&resource.data.authorId==request.auth.uid;}
    }
    match /activity/{activityId}{allow create:if member(request.resource.data.spaceId)&&request.resource.data.actorId==request.auth.uid;allow read:if member(resource.data.spaceId);}
    match /invitations/{invitationId}{allow create:if member(request.resource.data.spaceId);allow read:if signedIn();allow delete:if signedIn()&&request.auth.uid==resource.data.invitedBy;}
  }
}

