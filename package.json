{
    "name":  "sidequest",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "engines":  {
                    "node":  "22.x"
                },
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "typecheck":  "tsc --noEmit",
                    "check":  "npm run typecheck \u0026\u0026 npm run build",
                    "test:rules":  "firebase emulators:exec --only firestore,storage \"node --test tests/rules.test.mjs\"",
                    "test:onboarding":  "node --test tests/onboarding-render.test.mjs",
                    "test:templates":  "node --test tests/templates.test.mjs",
                    "test:space-templates":  "node --test tests/space-template-flow.test.mjs",
                    "test:category-packs":  "node --test tests/category-packs.test.mjs",
                    "test:starter-ideas":  "node --test tests/starter-ideas.test.mjs",
                    "test:idea-picker":  "node --test tests/idea-template-picker.test.mjs",
                    "test:template-editor":  "node --test tests/template-editor.test.mjs",
                    "test:idea-cards":  "node --test tests/idea-cards.test.mjs",
                    "test:idea-details":  "node --test tests/idea-template-details.test.mjs",
                    "test:inspiration":  "node --test tests/inspiration-catalog.test.mjs",
                    "test:seasonal":  "node --test tests/seasonal-inspiration.test.mjs",
                    "test:help":  "node --test tests/help-content.test.mjs",
                    "test:version-history":  "node --test tests/version-history.test.mjs"
                },
    "dependencies":  {
                         "firebase":  "^12.16.0",
                         "lucide-react":  "^0.487.0",
                         "motion":  "^12.23.24",
                         "react":  "18.3.1",
                         "react-dom":  "18.3.1"
                     },
    "devDependencies":  {
                            "@firebase/rules-unit-testing":  "^5.0.1",
                            "@types/react":  "^19.2.17",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^4.7.0",
                            "firebase-tools":  "^15.23.0",
                            "typescript":  "^5.8.3",
                            "vite":  "^6.3.5"
                        }
}